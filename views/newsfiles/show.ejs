<% layout("/layouts/boilerplate") -%>
<style>
    body{
        padding:0;
            margin:0;
            background-color: #b7b777;
            color:#fff;
    }
</style>
    <body>
        <div>
            <div class="col col-lg-7 offset-lg-2   col-sm-4 offset-.7">
                <h3>  &nbsp;News Details</h3>
                <div class="card">
                    <img class="card-img-top custom_img" src="<%=news.image.url %>" alt="<%=news.image.filename %>">
                    <div class="card-body">
                        <p class="card-text">
                            <%=news.title %> <br>
                                <%=news.description %> <br>
                                    &#8377;<%=news.price.toLocaleString("en-IN") %> <br>
                                        <%=news.location %> <br>
                                            <%=news.country %> <br> <br>
                        </p>
                    </div>
                     <div class="d-flex align-items-stretch">
                        <form method="put" action="/news/<%=news._id%>/edit">
                            <button class="btn btn-warning">Update</button>
                        </form> &nbsp;  &nbsp; 
                        <form method="post" action="/news/<%=news._id %>?_method=delete">
                            <button class="btn btn-danger">delete</button>
                        </form>
                     </div>
                </div>
            </div>
        </div>
        <br>
    </body>